<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">x86</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>OPC_DA_Agent</RootNamespace>
    <AssemblyName>OPC_DA_Agent</AssemblyName>
    <TargetFrameworkVersion>v4.0</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x86' ">
    <!-- 强制 32 位：OPC Automation (OPCServer CLSID 28E68F9A) 是 32 位进程内 COM 服务器，
         64 位进程在 64 位系统下看不到 WOW6432Node 中注册的它，会报 REGDB_E_CLASSNOTREG。
         参考程序 dayidata 用 Prefer32Bit=true 以 32 位运行，故能连接。 -->
    <PlatformTarget>x86</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x86' ">
    <!-- 强制 32 位：与 Debug 一致，保证 OPC Automation COM 服务器可被找到 -->
    <PlatformTarget>x86</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Web" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Xml" />
    <!-- Newtonsoft.Json：packages.config 还原后由 HintPath 显式引用（旧式 csproj 不会自动注入） -->
    <Reference Include="Newtonsoft.Json">
      <HintPath>packages\Newtonsoft.Json.13.0.3\lib\net40\Newtonsoft.Json.dll</HintPath>
    </Reference>
    <!--
      关键：仅使用参考程序编译出的 Interop.OPCAutomation.dll，不再使用 COMReference。
      COMReference 会在 CI 上按“本机类型库版本”重新生成互操作程序集，
      导致其内嵌的 CLSID 与“能运行参考程序的 Windows 机器”注册的不一致，
      从而在运行时报 REGDB_E_CLASSNOTREG (0x80040154)。
      改用 HintPath 直接引用参考程序的 Interop.OPCAutomation.dll，
      可保证 new OPCServer() 实例化的 CLSID {28E68F9A-8D75-11D1-8DC3-3C302A000000}
      与参考程序完全一致，运行时由同一台机器已注册的 OPC 自动化 COM 服务器提供。
      该互操作 DLL 会在编译后复制到输出目录，运行时由它提供 CLSID。
    -->
    <Reference Include="Interop.OPCAutomation">
      <HintPath>$(ProjectDir)Interop.OPCAutomation.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <!-- Main project files -->
    <Compile Include="Program.cs" />
    <Compile Include="Config.cs" />
    <Compile Include="Logger.cs" />
    <Compile Include="OPCService.cs" />
    <Compile Include="HttpServer.cs" />
    <Compile Include="DataModel.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="App.config" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="OPCDAAuto.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="web\index.html">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
